@model parcial_2026_1.Models.ViewModels.MisSolicitudesViewModel
@using parcial_2026_1.Models

@{
    ViewData["Title"] = "Mis Solicitudes";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Mis Solicitudes</h2>
        <a asp-action="Create" class="btn btn-success shadow-sm"><i class="bi bi-plus-circle"></i> Nueva Solicitud</a>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form asp-action="Index" method="get">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="row g-3">
                    <div class="col-md-2">
                        <label asp-for="Estado" class="form-label"></label>
                        <select asp-for="Estado" class="form-select" asp-items="Html.GetEnumSelectList<EstadoSolicitud>()">
                            <option value="">Todos</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label asp-for="MontoMinimo" class="form-label"></label>
                        <input asp-for="MontoMinimo" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="MontoMinimo" class="text-danger"></span>
                    </div>
                    <div class="col-md-2">
                        <label asp-for="MontoMaximo" class="form-label"></label>
                        <input asp-for="MontoMaximo" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="MontoMaximo" class="text-danger"></span>
                    </div>
                    <div class="col-md-2">
                        <label asp-for="FechaInicio" class="form-label"></label>
                        <input asp-for="FechaInicio" class="form-control" type="date" />
                        <span asp-validation-for="FechaInicio" class="text-danger"></span>
                    </div>
                    <div class="col-md-2">
                        <label asp-for="FechaFin" class="form-label"></label>
                        <input asp-for="FechaFin" class="form-control" type="date" />
                        <span asp-validation-for="FechaFin" class="text-danger"></span>
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary w-100">Filtrar</button>
                    </div>
                </div>
                <div class="row mt-2">
                    <div class="col-12">
                        <span asp-validation-for="FechaInicio" class="text-danger d-block"></span>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Fecha</th>
                            <th>Monto Solicitado</th>
                            <th>Estado</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Solicitudes != null)
                        {
                            @foreach (var item in Model.Solicitudes)
                            {
                                <tr>
                                    <td>#@item.Id</td>
                                    <td>@item.FechaSolicitud.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@item.MontoSolicitado.ToString("C")</td>
                                    <td>
                                        @if (item.Estado == EstadoSolicitud.Pendiente)
                                        {
                                            <span class="badge bg-warning text-dark">Pendiente</span>
                                        }
                                        else if (item.Estado == EstadoSolicitud.Aprobado)
                                        {
                                            <span class="badge bg-success">Aprobado</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Rechazado</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Detalles</a>
                                    </td>
                                </tr>
                            }
                            @if (!Model.Solicitudes.Any())
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-4 text-muted">No se encontraron solicitudes con los filtros aplicados.</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
